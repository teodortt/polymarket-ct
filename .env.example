# ── Your wallet (копиращ) ──────────────────────────────────────
PRIVATE_KEY=0xyour_private_key_here
SIGNATURE_TYPE=0
FUNDER_ADDRESS=0xyour_wallet_address_here

# ── Wallets за следене ─────────────────────────────────────────
# Един:
TARGET_WALLET=0xwallet_to_copy
# Или много (може да се добавят и през Telegram):
# TARGET_WALLETS=0xwallet1,0xwallet2,0xwallet3

# ── Telegram ───────────────────────────────────────────────────
# 1. Създай бот от @BotFather -> вземи TOKEN
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff
# 2. Вземи chat ID от @userinfobot или @getmyid_bot
TELEGRAM_CHAT_ID=123456789

# ── Trading config ─────────────────────────────────────────────
POLL_INTERVAL_MS=10000
COPY_SIZE_USDC=0
SIZE_MULTIPLIER=1.0
MAX_TRADE_USDC=100
DRY_RUN=true
